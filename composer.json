{
    "name": "consolidated-witchcraft/binding-engine-conflicts",
    "description": "Deterministic, provenance-aware semantic conflict detection for the BindingEngine ecosystem.",
    "type": "library",
    "license": "AGPL-3.0-or-later",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/consolidated-witchcraft/binding-engine-parser.git",
            "no-api": true
        },
        {
            "type": "vcs",
            "url": "https://github.com/consolidated-witchcraft/binding-engine-vocabulary.git",
            "no-api": true
        },
        {
            "type": "vcs",
            "url": "https://github.com/consolidated-witchcraft/binding-engine-vocabulary-loader.git",
            "no-api": true
        },
        {
            "type": "vcs",
            "url": "https://github.com/consolidated-witchcraft/binding-engine-assertions.git",
            "no-api": true
        },
        {
            "type": "vcs",
            "url": "https://github.com/consolidated-witchcraft/binding-engine-projection.git",
            "no-api": true
        }
    ],
    "require": {
        "php": "^8.4",
        "symfony/console": "^7.0",
        "consolidated-witchcraft/binding-engine-parser": ">=0.1.0 <1.0.0",
        "consolidated-witchcraft/binding-engine-vocabulary": ">=0.2.0 <1.0.0",
        "consolidated-witchcraft/binding-engine-vocabulary-loader": ">=0.2.0 <1.0.0",
        "consolidated-witchcraft/binding-engine-assertions": ">=0.1.0 <1.0.0",
        "consolidated-witchcraft/binding-engine-projection": ">=0.1.0 <1.0.0"
    },
    "autoload": {
        "psr-4": {
            "ConsolidatedWitchcraft\\BindingEngineConflicts\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Sam Baynham",
            "email": "sam.baynham@gmail.com"
        }
    ],
    "scripts": {
        "hooks:install": [
            "git config core.hooksPath .githooks",
            "chmod +x .githooks/pre-commit"
        ],
        "php-cs:check": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --verbose --sequential",
        "php-cs:fix": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --verbose --sequential",
        "test": "pest",
        "stan": "php -d memory_limit=1G vendor/bin/phpstan analyse"
    },
    "minimum-stability": "dev",
    "require-dev": {
        "friendsofphp/php-cs-fixer": "dev-master",
        "pestphp/pest": "5.x-dev",
        "phpstan/phpstan": "2.2.x-dev",
        "symfony/var-dumper": "8.1.x-dev"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
